---
import Base from "../layouts/Base.astro";
import { SITE } from "../content/site";
import SectionH from "../components/SectionH.astro";
import WorkItem from "../components/WorkItem.astro";
import BioParagraph from "../components/BioParagraph.astro";
import Ticker from "../components/Ticker.tsx";
import Cursor from "../components/Cursor.tsx";
import CmdK from "../components/CmdK.tsx";
---

<Base title={SITE.fullName} description={SITE.oneliner}>
  <main class="page">
    <div class="container">
      <button class="theme-toggle" type="button" aria-label="Toggle dark mode" data-theme-toggle>
        dark
      </button>

      <div class="identity">
        <h1 class="hero">ihsaan</h1>
        <p class="dek">{SITE.positioning}</p>
        <div class="meta-line">
          <Ticker client:load timezone={SITE.timezone} />
        </div>
      </div>

      <div class="split">
        <section class="primary">
          <section class="bio-block">
            <SectionH>bio</SectionH>
            <BioParagraph segments={SITE.bioSegments} />
          </section>

          <SectionH>work</SectionH>
          {SITE.work.map((w, i) => <WorkItem w={w} i={i} />)}

          <SectionH>projects</SectionH>
          {SITE.projects.map((w, i) => <WorkItem w={w} i={i} />)}

        </section>

        <aside class="rail" aria-label="secondary information">
          <SectionH>elsewhere</SectionH>
          <div class="elsewhere-list">
            {SITE.links.map((l) => (
              <a href={l.href} target="_blank" rel="noopener" class="mini-link">{l.label}</a>
            ))}
          </div>

          {SITE.writing.length > 0 && (
            <>
              <SectionH>writing</SectionH>
              <div class="mini-list">
                {SITE.writing.map((w) => (
                  <div class="mini-row">
                    <span>{w.title}</span>
                    <span class="quiet">{w.date}</span>
                  </div>
                ))}
              </div>
            </>
          )}

          <SectionH>reading</SectionH>
          <div class="mini-list">
            {SITE.reading.slice(0, 4).map((b) => (
              <div class="mini-row book">
                <span>{b.title}</span>
                <span class="quiet">{b.author}</span>
              </div>
            ))}
          </div>

        </aside>
      </div>

      <footer class="bottombar">
        <Cursor client:load />
        <CmdK client:load />
      </footer>
    </div>
  </main>
</Base>

<script is:inline>
  const button = document.querySelector("[data-theme-toggle]");
  const setLabel = () => {
    if (!button) return;
    button.textContent = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
  };
  setLabel();
  button?.addEventListener("click", () => {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("theme", next);
    setLabel();
  });
</script>

<style>
  .page { min-height: 100vh; }
  .container {
    padding: 42px 48px 52px;
    width: min(100%, 920px);
    margin: 0 auto;
  }

  .theme-toggle {
    position: fixed;
    top: 18px;
    right: 20px;
    z-index: 2;
    padding: 3px 8px;
    border: 1px solid var(--faint);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    color: var(--quiet);
    font-family: var(--mono);
    font-size: 11px;
    line-height: 1.4;
  }
  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    color: var(--ink);
    border-color: var(--quiet);
    outline: none;
  }

  .identity {
    margin: 18px 0 30px;
  }

  .hero {
    margin: 0;
    width: max-content;
    max-width: 100%;
    font-family: "Newsreader", Georgia, serif;
    font-weight: 300;
    font-size: clamp(72px, 9vw, 116px);
    letter-spacing: -0.075em;
    line-height: 0.82;
    font-style: italic;
    transform: translateX(-4px);
    color: var(--ink);
    text-shadow: none;
  }

  .dek {
    max-width: 48ch;
    margin: 16px 0 0;
    color: var(--quiet);
    font-size: 13px;
    line-height: 1.5;
  }

  .meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-top: 12px;
    color: var(--quiet);
    font-size: 11px;
  }

  .split {
    display: flex;
    gap: 72px;
    align-items: flex-start;
  }

  .primary { flex: 1 1 0; min-width: 0; }
  .bio-block { margin-top: 0; }

  .rail {
    flex: 0 0 235px;
    min-width: 0;
  }

  .mini-list {
    display: grid;
    gap: 9px;
  }

  .mini-row {
    display: grid;
    gap: 1px;
    font-size: 11.5px;
    line-height: 1.35;
  }
  .elsewhere-list {
    display: grid;
    grid-template-columns: repeat(2, max-content);
    gap: 7px 18px;
    font-size: 12px;
  }

  .mini-row.book { gap: 0; }
  .mini-link {
    color: inherit;
    text-decoration: none;
  }
  .mini-link:hover,
  .mini-link:focus-visible {
    color: var(--accent);
    outline: none;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    font-size: 12px;
  }

  .bottombar {
    margin-top: 72px;
    padding-top: 0;
    border-top: 0;
    display: flex; justify-content: space-between;
    color: var(--quiet); font-size: 11px;
  }

  /* ───────── mobile ───────── */
  @media (max-width: 720px) {
    .container { padding: 28px 24px 40px; }
    .identity { margin-top: 12px; }
    .hero { font-size: 66px; letter-spacing: -0.06em; }
    .split { flex-direction: column; gap: 6px; }
    .rail { position: static; }
  }
</style>
